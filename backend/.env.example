# ═══════════════════════════════════════════════
#  SMARTIOUS BACKEND — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit the actual .env to Git
# ═══════════════════════════════════════════════

# ── Server ──────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ────────────────────────────────
# Get this from MongoDB Atlas → Cluster → Connect → Drivers
MONGODB_URI=

# ── JWT ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────
# Frontend URL — used to allow cross-origin requests
# Development:  http://localhost:5173
# Production:   https://smartioushomeschool.com
CLIENT_URL=https://smartioushomeschool.com

# ── Email (optional) ─────────────────────────────
EMAIL_USER=
EMAIL_PASS=
