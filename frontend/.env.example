# ═══════════════════════════════════════════════
#  SMARTIOUS FRONTEND — Environment Variables
#  Copy this file to .env and fill in your values
#  Set these in Netlify Dashboard → Site Settings → Environment Variables
# ═══════════════════════════════════════════════

# ── Backend API URL ──────────────────────────────
# Development: leave blank (Vite proxy handles /api → localhost:5000)
# Production:  your Render backend URL (no trailing slash)
VITE_API_URL=https://smartious-api.onrender.com
